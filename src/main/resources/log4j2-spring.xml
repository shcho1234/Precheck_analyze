<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{1} - %msg%n"
                           charset="UTF-8"/>
        </Console>
        <RollingFile name="File"
                     fileName="logs/precheck-analyze.log"
                     filePattern="logs/precheck-analyze-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{1} - %msg%n"
                           charset="UTF-8"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>
    <Loggers>
        <!-- Spring Boot가 System.out/err를 Log4j2로 브릿징할 때 사용하는 로거 — 완전 차단 -->
        <Logger name="sys_out" level="OFF"/>
        <Logger name="sys_err" level="OFF"/>
        <Logger name="com.sks.precheck" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>
        <Root level="ERROR">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>
</Configuration>
